root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 규칙 전역 disable 은 의존 규칙 충돌(if-else-wrapping requires discouraged-comment-location)을
# 일으켜 ktlint 자체를 깨뜨린다. 그래서 도메인 인라인 주석을 의도적으로 쓰는 파일에는
# @file:Suppress("ktlint:standard:discouraged-comment-location") 를 파일 단위로 단다.
[*.{kt,kts}]
ktlint_code_style = ktlint_official
max_line_length = 120

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
